{
  "name": "warehouse-app",
  "version": "1.0.0",
  "description": "Учёт склада с пользователями и правами",
  "type": "module",
  "scripts": {
    "build": "cd client && npm ci --include=dev && npm run build",
    "start": "node scripts/ensure-client-built.mjs && node server/index.js",
    "dev": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev:client:https": "cd client && DEV_HTTPS=1 npx vite --host",
    "dev:https": "node scripts/dev-https.mjs",
    "build:client": "cd client && npm ci --include=dev && npm run build",
    "prod": "npm run build:client && NODE_ENV=production node server/index.js",
    "generate-certs": "node server/generate-certs.js",
    "prod:https": "npm run build:client && NODE_ENV=production HTTPS=true node server/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node server/db/migrate.js",
    "db:migrate-users": "node server/db/migrate-users-fields.js",
    "db:migrate-roles": "node server/db/migrate-roles.js",
    "db:migrate-employment-org": "node server/db/migrate-employment-org.js",
    "db:migrate-materials-price": "node server/db/migrate-materials-price.js",
    "db:migrate-card-uid": "node server/db/migrate-card-uid.js",
    "db:migrate-attendance": "node server/db/migrate-attendance.js",
    "db:seed": "node server/db/seed.js",
    "db:seed-card-uid": "node server/db/seed-card-uid.js",
    "db:seed-users": "node server/db/seed-random-users.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "xlsx": "^0.18.5"
  }
}
